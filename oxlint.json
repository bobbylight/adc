{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "vitest", "import", "jsx-a11y", "unicorn"],
  "options": {
    "maxWarnings": 0
  },
  "ignorePatterns": ["**/node_modules/**", "**/dist/**", "backend/bin/**", "backend/*.d.ts"],
  "env": {
    "es2022": true
  },
  "rules": {
    "react/jsx-filename-extension": [ "error", { "extensions": [".tsx"] } ],
    "react/react-in-jsx-scope": "off",
    "react/no-unstable-nested-components": ["error", { "allowAsProps": true }],
    "no-console": "warn",
    "vitest/require-mock-type-parameters": "off",
    "import/no-unassigned-import": ["error", { "allow": ["@testing-library/jest-dom"] }],

    // TODO: Review these individually later
    "capitalized-comments": "off",
    "func-style": "off",
    "max-params": [ "error", { "max": 4 } ],
    "no-magic-numbers": "off",
    "no-ternary": "off", // Used om spe TSX
    "sort-imports": "off", // Let import plugin do this
    "typescript/consistent-type-imports": "off",
    "import/consistent-type-specifier-style": "off",
    "import/exports-last": "off",
    "import/no-default-export": "off", // Unfortunately storybook requires default exports
    "import/no-named-export": "off",
    "import/prefer-default-export": "off",
    "unicorn/no-null": "off",
    "vitest/require-hook": "off",
    "vitest/no-hooks": "off",
    "vitest/no-importing-vitest-globals": "off",
    "vitest/prefer-called-times": "off",
    "vitest/prefer-expect-assertions": [ "error", { "onlyFunctionsWithAsyncKeyword": true } ],
    "vitest/prefer-lowercase-title": "off",
    "vitest/prefer-to-be-truthy": "off",
    "vitest/require-test-timeout": "off" // Global default is fine and avoids cluttering tests
  },
  "categories": {
    "correctness": "error",
    "perf": "error",
    "restriction": "error",
    "style": "error",
    "suspicious": "error"
  },
  "overrides": [
    {
      "files": ["frontend/src/**/*.{ts,tsx}"],
      "env": { "browser": true },
      "rules": {
        "react/jsx-max-depth": ["error", { "max": 5 }]
      }
    },
    {
      "files": ["backend/**/*.ts"],
      "env": { "node": true },
      "rules": {
        "max-statements": "off"
      }
    }
  ]
}
